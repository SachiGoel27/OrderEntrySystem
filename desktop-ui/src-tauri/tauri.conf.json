{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OES Desktop",
  "version": "0.1.0",
  "identifier": "com.oes.desktop",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "OES Desktop",
        "width": 1320,
        "height": 860,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  },
  "plugins": {}
}
